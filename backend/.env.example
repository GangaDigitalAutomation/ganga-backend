NODE_ENV=development
HOST=127.0.0.1
PORT=8080
LOG_LEVEL=info

# Optional production database/redis. Leave unset for local fallback mode.
DATABASE_URL=
REDIS_URL=

PGLITE_PATH=./data/pglite
QUEUE_FILE_PATH=./data/upload-queue.json
QUEUE_POLL_MS=1000
WORKER_CONCURRENCY=2
SCHEDULER_TICK_MS=15000

SIMULATION_MODE=true
SIMULATION_FAIL_RATE=0.08
SIMULATION_MIN_MS=900
SIMULATION_MAX_MS=3500
YOUTUBE_DAILY_QUOTA_PER_CHANNEL=8000
YOUTUBE_UPLOAD_QUOTA_UNITS=1600
YOUTUBE_PRIVACY_STATUS=private
YOUTUBE_DEFAULT_DESCRIPTION=
YOUTUBE_DEFAULT_TAGS=

AUTH_REQUIRED=false
JWT_SECRET=change-this-in-production
ALLOWED_EMAILS=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
TOKEN_ENCRYPTION_KEY=
