NODE_ENV=production
HOST=0.0.0.0
PORT=8080
LOG_LEVEL=info

DATABASE_URL=
REDIS_URL=
PGLITE_PATH=./data/pglite
QUEUE_FILE_PATH=./data/upload-queue.json
QUEUE_POLL_MS=1000
WORKER_CONCURRENCY=4
SCHEDULER_TICK_MS=15000

SIMULATION_MODE=false
SIMULATION_FAIL_RATE=0.05
SIMULATION_MIN_MS=1200
SIMULATION_MAX_MS=5000

YOUTUBE_DAILY_QUOTA_PER_CHANNEL=8000
YOUTUBE_UPLOAD_QUOTA_UNITS=1600
YOUTUBE_PRIVACY_STATUS=private
YOUTUBE_DEFAULT_DESCRIPTION=
YOUTUBE_DEFAULT_TAGS=

AUTH_REQUIRED=true
JWT_SECRET=replace-with-strong-secret
ALLOWED_EMAILS=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
FRONTEND_URL=https://your-frontend.vercel.app
TOKEN_ENCRYPTION_KEY=replace-with-32+-char-secret
