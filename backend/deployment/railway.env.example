# Required user values
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
ALLOWED_EMAILS=

# App
NODE_ENV=production
HOST=0.0.0.0
PORT=8080
LOG_LEVEL=info

# Database and queue (Railway plugins)
DATABASE_URL=
REDIS_URL=

# Safe defaults
SIMULATION_MODE=true
SIMULATION_FAIL_RATE=0.05
SIMULATION_MIN_MS=900
SIMULATION_MAX_MS=3500
AUTH_REQUIRED=true

# Security
JWT_SECRET=replace-with-strong-secret
TOKEN_ENCRYPTION_KEY=replace-with-32-plus-char-secret

# Google OAuth
GOOGLE_REDIRECT_URI=https://YOUR_BACKEND_DOMAIN/api/auth/google/callback

# Scheduler and worker
QUEUE_POLL_MS=1000
WORKER_CONCURRENCY=2
SCHEDULER_TICK_MS=15000

# Quota
YOUTUBE_DAILY_QUOTA_PER_CHANNEL=8000
YOUTUBE_UPLOAD_QUOTA_UNITS=1600
YOUTUBE_PRIVACY_STATUS=private
YOUTUBE_DEFAULT_DESCRIPTION=
YOUTUBE_DEFAULT_TAGS=
