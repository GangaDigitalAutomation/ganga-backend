{
  "name": "sandbox-app",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:api": "tsx watch src/index.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "dev:scheduler": "tsx watch src/scheduler.ts",
    "build": "esbuild src/index.ts src/worker.ts src/scheduler.ts --bundle --outdir=dist --platform=node --target=node20 --format=esm --packages=external --sourcemap --tsconfig=tsconfig.json",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "start:worker": "node dist/worker.js",
    "start:scheduler": "node dist/scheduler.js",
    "db:generate": "tsx node_modules/drizzle-kit/bin.cjs generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:push": "npm run db:generate && npm run db:migrate",
    "validate:timing": "tsx src/scripts/validateHumanTiming.ts",
    "test:e2e:automation": "tsx src/scripts/e2eAutomation.ts"
  },
  "dependencies": {
    "@electric-sql/pglite": "0.2.17",
    "@fastify/aws-lambda": "6.1.1",
    "@fastify/cors": "10.1.0",
    "@fastify/multipart": "9.3.0",
    "@fastify/rate-limit": "10.3.0",
    "@fastify/swagger": "9.6.1",
    "@fastify/websocket": "11.2.0",
    "@neondatabase/serverless": "1.0.2",
    "better-auth": "1.4.5",
    "bullmq": "5.71.1",
    "commander": "12.1.0",
    "dotenv": "16.6.1",
    "drizzle-orm": "0.44.7",
    "fastify": "5.7.1",
    "googleapis": "^140.0.0",
    "ioredis": "5.10.1",
    "jose": "6.2.2",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "4.2.1",
    "pino-pretty": "13.1.3",
    "postgres": "3.4.7"
  },
  "devDependencies": {
    "@types/node": "22.19.15",
    "drizzle-kit": "0.31.5",
    "esbuild": "0.27.4",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  }
}
