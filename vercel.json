{
  "version": 2,
  "cleanUrls": true,
  "rewrites": [
    { "source": "/", "destination": "/renderer/index.html" },
    { "source": "/app.js", "destination": "/renderer/app.js" },
    { "source": "/styles.css", "destination": "/renderer/styles.css" },
    { "source": "/setup-assistant", "destination": "/deployment/setup-assistant.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
